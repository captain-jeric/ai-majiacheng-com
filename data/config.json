{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.5-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.2,
    "max_tokens": 1024,
    "throttle_sec": 0,
    "analysis_concurrency": 3,
    "enrichment_concurrency": 2,
    "languages": ["zh"]
  },
  "email": {
    "enabled": false,
    "imap_enabled": false,
    "smtp_server": "smtp.qq.com",
    "smtp_port": 465,
    "imap_server": "imap.qq.com",
    "imap_port": 993,
    "email_address": "news@majiacheng.com",
    "sender_name": "AI Majiacheng Daily",
    "subscribe_keyword": "SUBSCRIBE",
    "unsubscribe_keyword": "UNSUBSCRIBE"
  },
  "sources": {
    "github": [
      {
        "type": "repo_releases",
        "owner": "ollama",
        "repo": "ollama",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "huggingface",
        "repo": "transformers",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "vllm-project",
        "repo": "vllm",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "langchain-ai",
        "repo": "langchain",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "microsoft",
        "repo": "autogen",
        "enabled": true
      },
      {
        "type": "repo_releases",
        "owner": "openai",
        "repo": "openai-python",
        "enabled": true
      }
    ],
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 20,
      "min_score": 250
    },
    "rss": [
      {
        "name": "OpenAI Blog",
        "url": "https://openai.com/news/rss.xml",
        "enabled": true,
        "category": "ai-products"
      },
      {
        "name": "Google AI Blog",
        "url": "https://blog.google/technology/ai/rss/",
        "enabled": true,
        "category": "ai-products"
      },
      {
        "name": "Google Research Blog",
        "url": "https://research.google/blog/rss/",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "MIT Technology Review",
        "url": "https://www.technologyreview.com/feed/",
        "enabled": true,
        "category": "ai-industry"
      },
      {
        "name": "Hugging Face Blog",
        "url": "https://huggingface.co/blog/feed.xml",
        "enabled": true,
        "category": "open-source-ai"
      },
      {
        "name": "Simon Willison",
        "url": "https://simonwillison.net/atom/everything/",
        "enabled": true,
        "category": "ai-tools"
      },
      {
        "name": "Latent Space",
        "url": "https://www.latent.space/feed",
        "enabled": true,
        "category": "ai-industry"
      },
      {
        "name": "VentureBeat AI",
        "url": "https://venturebeat.com/category/ai/feed/",
        "enabled": true,
        "category": "ai-industry"
      },
      {
        "name": "MIT News AI",
        "url": "https://news.mit.edu/topic/mitartificial-intelligence2-rss.xml",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "MarkTechPost",
        "url": "https://www.marktechpost.com/feed/",
        "enabled": true,
        "category": "ai-research"
      },
      {
        "name": "NVIDIA AI Blog",
        "url": "https://developer.nvidia.com/blog/category/artificial-intelligence/feed/",
        "enabled": true,
        "category": "ai-infra"
      },
      {
        "name": "NVIDIA Technical Blog AI",
        "url": "https://developer.nvidia.com/blog/category/deep-learning/feed/",
        "enabled": true,
        "category": "ai-infra"
      }
    ],
    "reddit": {
      "enabled": false,
      "subreddits": [
        {
          "subreddit": "MachineLearning",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 80
        },
        {
          "subreddit": "LocalLLaMA",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 20,
          "min_score": 80
        },
        {
          "subreddit": "OpenAI",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 60
        },
        {
          "subreddit": "singularity",
          "enabled": true,
          "sort": "top",
          "time_filter": "day",
          "fetch_limit": 15,
          "min_score": 120
        }
      ],
      "users": [],
      "fetch_comments": 5
    },
    "telegram": {
      "enabled": false,
      "channels": []
    },
    "twitter": {
      "enabled": false,
      "users": [],
      "fetch_limit": 10,
      "fetch_reply_text": false,
      "max_replies_per_tweet": 3,
      "max_tweets_to_expand": 10,
      "reply_min_likes": 5
    },
    "openbb": {
      "enabled": false,
      "fetch_filings": false,
      "filings_provider": "sec",
      "watchlists": []
    },
    "ossinsight": {
      "enabled": true,
      "period": "past_24_hours",
      "languages": ["All", "Python", "TypeScript"],
      "keywords": [
        "ai",
        "agent",
        "agents",
        "llm",
        "rag",
        "inference",
        "transformer",
        "diffusion",
        "embedding",
        "copilot"
      ],
      "min_stars": 20,
      "max_items": 8
    }
  },
  "filtering": {
    "ai_score_threshold": 5.8,
    "time_window_hours": 24,
    "max_items": 10,
    "category_groups": {
      "models": {
        "name": "Models and research",
        "limit": 7,
        "categories": ["ai-research", "ai-products"]
      },
      "open_source": {
        "name": "Open source AI",
        "limit": 5,
        "categories": ["open-source-ai", "ai-tools", "ai-infra"]
      },
      "industry": {
        "name": "Industry",
        "limit": 4,
        "categories": ["ai-industry"]
      }
    },
    "default_group": "other",
    "default_group_limit": 5
  },
  "webhook": {
    "enabled": false,
    "url_env": "HORIZON_WEBHOOK_URL",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "text": "#{message_title}\n#{summary}"
    },
    "headers": ""
  }
}
